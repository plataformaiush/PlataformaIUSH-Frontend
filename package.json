{
  "name": "iush-platform",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "dev:fast": "vite --config vite.config.dev.ts",
    "build": "tsc --project config/tsconfig.json && vite build --config config/vite.config.ts",
    "build:fast": "vite build --config vite.config.dev.ts",
    "build:dev": "tsc --project config/tsconfig.json && vite build --config vite.config.dev.ts",
    "preview": "vite preview --config config/vite.config.ts",
    "test": "vitest --config config/vitest.config.ts",
    "test:coverage": "vitest --config config/vitest.config.ts --coverage",
    "test:ui": "vitest --config config/vitest.config.ts --ui",
    "lint": "eslint . --config config/eslint.config.js --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --config config/eslint.config.js --ext ts,tsx --fix",
    "type-check": "tsc --project config/tsconfig.json --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css,md}\""
  },
  "dependencies": {
    "@hookform/resolvers": "^3.9.1",
    "@react-pdf/renderer": "^4.1.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tanstack/react-query": "^5.62.0",
    "axios": "^1.7.9",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "js-cookie": "^3.0.5",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.9.0",
    "plausible-tracker": "^0.3.9",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-pdf": "^9.2.0",
    "react-player": "^2.16.0",
    "react-router-dom": "^7.1.0",
    "regenerator-runtime": "^0.14.0",
    "tailwind-merge": "^2.6.0",
    "exceljs": "^4.4.0",
    "uuid": "^9.0.1",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/js-cookie": "^3.0.6",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-legacy": "^6.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^2.1.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "jsdom": "^25.0.1",
    "msw": "^2.7.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "prettier-plugin-tailwindcss": "^0.6.9",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.4.2",
    "vitest": "^2.1.8"
  }
}
